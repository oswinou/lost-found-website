<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Game Library - Register</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="auth-body">
  <div class="auth-card">
    <h1 class="auth-title">Create Account</h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/register" class="auth-form">
      <label class="auth-label">Username</label>
      <input type="text" name="username" class="auth-input" required />

      <label class="auth-label">Password</label>
      <input type="password" name="password" class="auth-input" required />

      <label class="auth-label">Confirm Password</label>
      <input type="password" name="confirmPassword" class="auth-input" required />

      <button type="submit" class="auth-button primary">Register</button>
    </form>

    <p class="auth-footer">
      Already have an account?
      <a href="/login">Back to login</a>
    </p>
  </div>
</body>
</html>

