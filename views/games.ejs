<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Game Library</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #e0f2ff, #f5f7ff);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: #1f2933;
    }

    .page {
      width: 100%;
      max-width: 1080px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .title {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 0.03em;
      color: #111827;
    }

    .user-info {
      font-size: 14px;
      color: #4b5563;
    }

    .user-info strong {
      color: #111827;
    }

    .link {
      color: #2563eb;
      text-decoration: none;
      font-weight: 500;
      margin-left: 6px;
    }

    .link:hover {
      text-decoration: underline;
    }

    .card {
      background: #ffffff;
      border-radius: 16px;
      padding: 20px 24px 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
      border: 1px solid rgba(148, 163, 184, 0.25);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .card-title {
      font-size: 18px;
      font-weight: 600;
      color: #111827;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 8px 14px;
      border-radius: 999px;
      background: linear-gradient(135deg, #2563eb, #1d4ed8);
      color: #ffffff;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      border: none;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.35);
      transition: transform 0.05s ease, box-shadow 0.05s ease, opacity 0.1s ease;
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 18px rgba(37, 99, 235, 0.45);
      opacity: 0.96;
    }

    .btn-primary:active {
      transform: translateY(0);
      box-shadow: 0 3px 10px rgba(37, 99, 235, 0.35);
      opacity: 0.9;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
      font-size: 14px;
    }

    thead {
      background: #f3f4ff;
    }

    th, td {
      padding: 10px 12px;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }

    th {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #6b7280;
    }

    tbody tr:hover {
      background: #f9fafb;
    }

    .rating {
      font-weight: 600;
      color: #111827;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .status-backlog {
      background: rgba(148, 163, 184, 0.16);
      color: #374151;
    }

    .status-playing {
      background: rgba(59, 130, 246, 0.16);
      color: #1d4ed8;
    }

    .status-cleared {
      background: rgba(52, 211, 153, 0.18);
      color: #047857;
    }

    .action-cell {
      white-space: nowrap;
      display: flex;
      gap: 6px;
    }

    .btn-link {
      font-size: 13px;
      border-radius: 999px;
      padding: 4px 10px;
      border: 1px solid #d1d5db;
      background: #f9fafb;
      color: #111827;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.1s ease, border-color 0.1s ease;
    }

    .btn-link:hover {
      background: #e5e7eb;
      border-color: #9ca3af;
    }

    .btn-danger {
      border-color: #fecaca;
      background: #fef2f2;
      color: #b91c1c;
    }

    .btn-danger:hover {
      border-color: #fca5a5;
      background: #fee2e2;
    }

    .empty-row td {
      text-align: center;
      padding: 24px 12px;
      color: #9ca3af;
      font-style: italic;
    }

    @media (max-width: 720px) {
      .card {
        padding: 16px;
      }
      .title {
        font-size: 22px;
      }
      th, td {
        padding: 8px 6px;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <div class="title">Game Library</div>
      <div class="user-info">
        Signed in as <strong><%= user ? user.username : 'Guest' %></strong>.
        <a href="/logout" class="link">Logout</a>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">Your games</div>
        <a href="/games/add" class="btn-primary">+ Add New Game</a>
      </div>

      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Platform</th>
            <th>Genre</th>
            <th>Rating</th>
            <th>Status</th>
            <th style="width: 130px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!games || games.length === 0) { %>
            <tr class="empty-row">
              <td colspan="6">No games yet. Click “Add New Game” to create one.</td>
            </tr>
          <% } else { %>
            <% games.forEach(game => { %>
              <tr>
                <td><%= game.title %></td>
                <td><%= game.platform %></td>
                <td><%= game.genre %></td>
                <td><span class="rating"><%= game.rating %></span></td>
                <td>
                  <span class="status-badge status-<%= (game.status || '').toLowerCase() %>">
                    <%= game.status %>
                  </span>
                </td>
                <td>
                  <div class="action-cell">
                    <a href="/games/edit/<%= game._id %>" class="btn-link">Edit</a>
                    <form
                      action="/games/delete/<%= game._id %>"
                      method="POST"
                      style="display:inline;"
                      onsubmit="return confirm('Are you sure you want to delete this game?');"
                    >
                      <button type="submit" class="btn-link btn-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>

