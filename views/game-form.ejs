<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= mode === 'edit' ? 'Edit Game' : 'Add Game' %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="auth-body">
  <div class="auth-card">
    <h1 class="auth-title">
      <%= mode === 'edit' ? 'Edit Game' : 'Add New Game' %>
    </h1>

    <% if (error) { %>
      <div class="auth-error"><%= error %></div>
    <% } %>

    <form
      method="POST"
      action="<%= mode === 'edit'
        ? '/games/edit/' + game._id
        : '/games/add' %>"
      class="auth-form"
    >
      <!-- Title -->
      <label class="auth-label">Title</label>
      <input
        type="text"
        name="title"
        class="auth-input"
        value="<%= game.title || '' %>"
        required
      />

      <!-- Platform -->
      <label class="auth-label">Platform</label>
      <input
        type="text"
        name="platform"
        class="auth-input"
        value="<%= game.platform || '' %>"
        required
      />

      <!-- Genre -->
      <label class="auth-label">Genre</label>
      <input
        type="text"
        name="genre"
        class="auth-input"
        value="<%= game.genre || '' %>"
        required
      />

      <!-- Rating -->
      <label class="auth-label">Rating (0–10)</label>
      <input
        type="number"
        name="rating"
        min="0"
        max="10"
        step="0.5"
        class="auth-input"
        value="<%= typeof game.rating !== 'undefined' ? game.rating : '' %>"
        required
      />

      <!-- Status -->
      <label class="auth-label">Status</label>
      <select name="status" class="auth-input">
        <% const currentStatus = game.status || 'backlog'; %>
        <option value="backlog" <%= currentStatus === 'backlog' ? 'selected' : '' %>>
          Backlog
        </option>
        <option value="playing" <%= currentStatus === 'playing' ? 'selected' : '' %>>
          Playing
        </option>
        <option value="cleared" <%= currentStatus === 'cleared' ? 'selected' : '' %>>
          Cleared
        </option>
      </select>

      <!-- Buttons -->
      <button type="submit" class="auth-button primary">
        <%= mode === 'edit' ? 'Update' : 'Create' %>
      </button>
    </form>

    <p class="auth-footer">
      <a href="/games">← Back to library</a>
    </p>
  </div>
</body>
</html>

