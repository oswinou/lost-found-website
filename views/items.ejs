<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Lost & Found Board</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <div class="page-header">
      <h1>Lost & Found Board</h1>
      <p>Find lost belongings faster and manage reports in one place.</p>
    </div>

    <div class="top-bar">
      <div class="user-info">
        Logged in as: <strong><%= user ? user.username : 'Guest' %></strong>
        <% if (user && user.role) { %>
          (<%= user.role %>)
        <% } %>
        | <a href="/logout">Logout</a>
      </div>

      <div>
        <a class="primary-btn" href="/items/add">+ Add New Item</a>
      </div>
    </div>

    <div class="search-panel">
      <form method="GET" action="/items">
        <div class="search-grid">
          <div>
            <label>Keyword</label>
            <input
              type="text"
              name="keyword"
              placeholder="Search by title, description, location"
              value="<%= query && query.keyword ? query.keyword : '' %>"
            >
          </div>

          <div>
            <label>Type</label>
            <select name="type">
              <option value="">All</option>
              <option value="lost" <%= query && query.type === 'lost' ? 'selected' : '' %>>Lost</option>
              <option value="found" <%= query && query.type === 'found' ? 'selected' : '' %>>Found</option>
            </select>
          </div>

          <div>
            <label>Category</label>
            <input
              type="text"
              name="category"
              placeholder="e.g. Wallet, Phone, Bag"
              value="<%= query && query.category ? query.category : '' %>"
            >
          </div>

          <div>
            <label>Per Page</label>
            <select name="perPage">
              <option value="4" <%= query && query.perPage == 4 ? 'selected' : '' %>>4</option>
              <option value="8" <%= query && query.perPage == 8 ? 'selected' : '' %>>8</option>
              <option value="12" <%= query && query.perPage == 12 ? 'selected' : '' %>>12</option>
            </select>
          </div>
        </div>

        <div class="button-row">
          <button class="primary-btn" type="submit">Search / Filter</button>
          <a class="secondary-btn" href="/items">Reset</a>
        </div>
      </form>
    </div>

    <% if (!items || items.length === 0) { %>
      <div class="empty-state">
        <h3>No items found</h3>
        <p>Try adding a new post or changing your search filters.</p>
      </div>
    <% } else { %>
      <div class="item-grid">
        <% items.forEach(item => { %>
          <%
            const isAdmin = user && user.role === 'admin';
            const isOwner = user && item.createdBy && String(item.createdBy._id) === String(user.id);
          %>

          <div class="item-card">
            <h3>
              <a href="/items/<%= item._id %>"><%= item.title %></a>
            </h3>

            <div class="badge-row">
              <span class="badge <%= item.type === 'lost' ? 'badge-lost' : 'badge-found' %>">
                <%= item.type %>
              </span>

              <span class="badge <%= item.status === 'resolved' ? 'badge-resolved' : 'badge-active' %>">
                <%= item.status %>
              </span>
            </div>

            <div class="meta-grid">
              <div class="meta-item">
                <strong>Category:</strong> <%= item.category %>
              </div>
              <div class="meta-item">
                <strong>Location:</strong> <%= item.location %>
              </div>
              <div class="meta-item">
                <strong>Date:</strong> <%= new Date(item.date).toLocaleDateString() %>
              </div>
              <div class="meta-item">
                <strong>Contact:</strong> <%= item.contactInfo %>
              </div>
            </div>

            <div class="item-description">
              <%= item.description && item.description.length > 20
                ? item.description.substring(0, 20) + '...'
                : item.description || '' %>
            </div>

            <% if (isAdmin || isOwner) { %>
              <div class="card-actions">
                <a class="secondary-btn" href="/items/edit/<%= item._id %>">Edit</a>

                <form class="inline-form" method="POST" action="/items/delete/<%= item._id %>">
                  <button
                    class="danger-btn"
                    type="submit"
                    onclick="return confirm('Delete this item?')"
                  >
                    Delete
                  </button>
                </form>

                <% if (item.status !== 'resolved') { %>
                  <form class="inline-form" method="POST" action="/items/resolve/<%= item._id %>">
                    <button class="success-btn" type="submit">Mark Resolved</button>
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (pagination && pagination.totalPages > 1) { %>
  <div class="pagination-bar">
    <div>
      <% if (pagination.currentPage > 1) { %>
        <a
          class="secondary-btn"
          href="/items?keyword=<%= encodeURIComponent(query.keyword || '') %>&type=<%= encodeURIComponent(query.type || '') %>&category=<%= encodeURIComponent(query.category || '') %>&perPage=<%= pagination.itemsPerPage %>&page=<%= pagination.currentPage - 1 %>"
        >
          Previous
        </a>
      <% } %>
    </div>

    <div class="pagination-info">
      Page <strong><%= pagination.currentPage %></strong> of <strong><%= pagination.totalPages %></strong>
    </div>

    <div>
      <% if (pagination.currentPage < pagination.totalPages) { %>
        <a
          class="secondary-btn"
          href="/items?keyword=<%= encodeURIComponent(query.keyword || '') %>&type=<%= encodeURIComponent(query.type || '') %>&category=<%= encodeURIComponent(query.category || '') %>&perPage=<%= pagination.itemsPerPage %>&page=<%= pagination.currentPage + 1 %>"
        >
          Next
        </a>
      <% } %>
    </div>
  </div>
<% } %>
  </div>
</body>
</html>