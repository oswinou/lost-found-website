<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login | Lost & Found Website</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-shell">
      <div class="auth-grid">
        <div class="auth-showcase">
          <h1>Lost & Found Website</h1>
          <p>
            Report lost items, browse found items, and manage item status in one simple platform.
          </p>

          <div class="mini-board">
            <div class="mini-board-title">Platform Features</div>

            <div class="mini-item">
              <div>
                <strong>Post Lost / Found Items</strong>
                <small>Create clear item records in seconds</small>
              </div>
              <span class="badge badge-found">Post</span>
            </div>

            <div class="mini-item">
              <div>
                <strong>Search and Filter</strong>
                <small>Find records by keyword, type, and category</small>
              </div>
              <span class="badge badge-active">Search</span>
            </div>

            <div class="mini-item">
              <div>
                <strong>Manage Status</strong>
                <small>Update, resolve, and track item posts</small>
              </div>
              <span class="badge badge-lost">Track</span>
            </div>
          </div>
        </div>

        <div class="auth-card">
          <h2>Login</h2>

          <% if (error) { %>
            <p class="error-text"><%= error %></p>
          <% } %>

          <% if (success) { %>
            <p style="color:#16a34a; font-weight:700;"><%= success %></p>
          <% } %>

          <form method="POST" action="/login">
            <div style="margin-bottom:16px;">
              <label>Username</label>
              <input type="text" name="username" required>
            </div>

            <div style="margin-bottom:16px;">
              <label>Password</label>
              <input type="password" name="password" required>
            </div>

            <div class="button-row">
              <button class="primary-btn" type="submit">Login</button>
            </div>
          </form>

          <p style="margin-top:22px;" class="helper-text">
            No account? <a href="/register">Register</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</body>
</html>